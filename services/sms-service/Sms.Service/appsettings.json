{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9094",
    "AlertsCreatedTopic": "alerts.created",
    "AlertsProcessedTopic": "alerts.processed",
    "AlertsDispatchedTopic": "alerts.dispatched",
    "AlertsFailedTopic": "alerts.failed",
    "ClientId": "sms-service"
  },
  "DispatcherSimulation": {
    "MaxRetries": 3,
    "BaseDelayMilliseconds": 500,
    "PushFailureRate": 0.35,
    "SmsFailureRate": 0.2,
    "EmailFailureRate": 0.15
  }
}
